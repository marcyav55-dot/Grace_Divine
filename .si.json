{
  "plugin": "org.smartide.plugin.nodejs",
  "run": "npm start",
  "intelligence": {
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".js": {
      "enabled": true,
      "run": "typescript-language-server --stdio"
    },
    ".py": {
      "enabled": true,
      "run": "pylsp"
    },
    ".md": {
      "enabled": true,
      "run": "marksman server"
    }
  }
}